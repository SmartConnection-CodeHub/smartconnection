---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);

const members = [
  { name: i.teamGuillermo, role: i.teamGuillermoRole, desc: i.teamGuillermoDesc, img: '/img/team/guillermo.jpg', social: [{ href: 'https://www.linkedin.com/in/guillermogonzalezleon/', icon: 'bi-linkedin' }, { href: 'mailto:guillermo.gonzalez@smconnection.cl', icon: 'bi-envelope' }] },
  { name: i.teamSAP, role: i.teamSAPRole, desc: i.teamSAPDesc, img: '/img/team/consultor-2.jpg', social: [{ href: 'https://www.linkedin.com/company/smconnection/', icon: 'bi-linkedin' }] },
  { name: i.teamApps, role: i.teamAppsRole, desc: i.teamAppsDesc, img: '/img/team/consultor-3.jpg', social: [{ href: 'https://github.com/guillermogonzalezleon-lgtm', icon: 'bi-github' }] },
];
---

<section id="equipo" class="relative py-24 bg-dark-bg-2/30">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase">{i.teamLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.teamTitle}</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">{i.teamDesc}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {members.map(member => (
        <div class="glass-card overflow-hidden hover:-translate-y-2 transition-all duration-300 animate-on-scroll">
          <div class="relative h-64 overflow-hidden">
            <img src={member.img} alt={member.name} loading="lazy" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="text-white font-bold text-lg">{member.name}</h3>
            <span class="text-primary text-sm font-medium">{member.role}</span>
            <p class="text-text-muted text-sm mt-2 leading-relaxed">{member.desc}</p>
            <div class="flex gap-3 mt-4">
              {member.social.map(s => (
                <a href={s.href} target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 flex items-center justify-center text-text-muted hover:text-primary hover:bg-primary/10 transition-all">
                  <i class={`bi ${s.icon}`}></i>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
