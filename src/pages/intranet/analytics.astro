---
export const prerender = false;
import { verifySession } from '../api/auth';

const session = verifySession(Astro.cookies.get('sc_session')?.value);
if (!session.valid) return Astro.redirect('/intranet');
---
<!DOCTYPE html>
<html lang="es-CL">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Analytics — Intranet Smart Connection</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="shortcut icon" href="/img/smart.ico">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --primary: #00c1c1; --primary-light: #00e5e5; --gold: #f0ab00; --bg: #0a0e17; --bg2: #111827; --text: #e2e8f0; --muted: #94a3b8; }
    body { font-family: 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    .topbar { background: var(--bg2); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; }
    .topbar img { height: 32px; }
    .topbar .badge { background: var(--primary); color: var(--bg); font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; }
    .topbar nav { margin-left: auto; display: flex; gap: 1rem; }
    .topbar nav a { color: var(--muted); font-size: 0.8rem; text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 8px; transition: all 0.2s; }
    .topbar nav a:hover, .topbar nav a.active { color: var(--primary); background: rgba(0,193,193,0.1); }
    .main { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }
    h1 i { color: var(--primary); }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: var(--bg2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 1.25rem; }
    .stat-card .label { color: var(--muted); font-size: 0.75rem; margin-bottom: 0.5rem; }
    .stat-card .value { font-size: 1.75rem; font-weight: 800; color: var(--primary); }
    .stat-card .sub { font-size: 0.7rem; color: var(--muted); margin-top: 0.25rem; }
    .section { background: var(--bg2); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .section h2 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .section h2 i { color: var(--primary); }
    .source-row { display: flex; align-items: center; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .source-row:last-child { border-bottom: none; }
    .source-name { font-size: 0.85rem; min-width: 120px; }
    .source-bar { flex: 1; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; }
    .source-bar-fill { height: 100%; border-radius: 4px; background: var(--primary); }
    .source-count { font-size: 0.8rem; color: var(--muted); min-width: 40px; text-align: right; }
    .page-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 0.8rem; }
    .page-row:last-child { border-bottom: none; }
  </style>
</head>
<body>
  <div class="topbar">
    <img src="/img/logo_smart.svg" alt="Smart Connection">
    <span class="badge">INTRANET</span>
    <nav>
      <a href="/intranet">Dashboard</a>
      <a href="/intranet/leads">Leads</a>
      <a href="/intranet/analytics" class="active">Analytics</a>
    </nav>
  </div>
  <div class="main">
    <h1><i class="bi bi-graph-up"></i> Analytics</h1>
    <div class="stats-grid">
      <div class="stat-card"><div class="label">Visitas hoy</div><div class="value" id="visitasHoy">0</div><div class="sub">pageviews</div></div>
      <div class="stat-card"><div class="label">Visitas semana</div><div class="value" id="visitasSemana">0</div><div class="sub">últimos 7 días</div></div>
      <div class="stat-card"><div class="label">Leads totales</div><div class="value" id="leadsTotal">0</div><div class="sub">formulario de contacto</div></div>
      <div class="stat-card"><div class="label">Reuniones</div><div class="value" id="reunionesTotal">0</div><div class="sub">agendadas</div></div>
    </div>
    <div class="section">
      <h2><i class="bi bi-diagram-3"></i> Fuentes de tráfico</h2>
      <div id="sourcesContainer"><p style="color:var(--muted);font-size:0.8rem">Cargando...</p></div>
    </div>
    <div class="section">
      <h2><i class="bi bi-file-earmark-text"></i> Páginas más visitadas</h2>
      <div id="pagesContainer"><p style="color:var(--muted);font-size:0.8rem">Cargando...</p></div>
    </div>
  </div>
  <script is:inline>
    function loadAnalytics() {
      fetch('/api/agents', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({action:'query', table:'analytics', order:'created_at.desc', limit:500}) })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (!d.data) return;
          var data = d.data;
          var today = new Date().toISOString().split('T')[0];
          var week = new Date(Date.now() - 7*86400000).toISOString();
          document.getElementById('visitasHoy').textContent = data.filter(function(e) { return e.created_at && e.created_at.startsWith(today); }).length;
          document.getElementById('visitasSemana').textContent = data.filter(function(e) { return e.created_at && e.created_at >= week; }).length;

          // Sources
          var sources = {};
          data.forEach(function(e) { var s = e.source || 'direct'; sources[s] = (sources[s]||0)+1; });
          var sorted = Object.entries(sources).sort(function(a,b) { return b[1]-a[1]; });
          var max = sorted[0] ? sorted[0][1] : 1;
          document.getElementById('sourcesContainer').innerHTML = sorted.slice(0,8).map(function(s) {
            return '<div class="source-row"><span class="source-name">' + s[0] + '</span><div class="source-bar"><div class="source-bar-fill" style="width:' + (s[1]/max*100) + '%"></div></div><span class="source-count">' + s[1] + '</span></div>';
          }).join('') || '<p style="color:var(--muted)">Sin datos</p>';

          // Pages
          var pages = {};
          data.forEach(function(e) { var p = e.page || '/'; pages[p] = (pages[p]||0)+1; });
          var sortedP = Object.entries(pages).sort(function(a,b) { return b[1]-a[1]; });
          document.getElementById('pagesContainer').innerHTML = sortedP.slice(0,10).map(function(p) {
            return '<div class="page-row"><span>' + p[0] + '</span><span style="color:var(--muted)">' + p[1] + ' views</span></div>';
          }).join('') || '<p style="color:var(--muted)">Sin datos</p>';
        }).catch(function() {});

      // Leads count
      fetch('/api/agents', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({action:'query', table:'leads', limit:1000}) })
        .then(function(r) { return r.json(); })
        .then(function(d) { if (d.data) document.getElementById('leadsTotal').textContent = d.data.length; })
        .catch(function() {});

      // Reuniones count
      fetch('/api/agents', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({action:'query', table:'reuniones', limit:1000}) })
        .then(function(r) { return r.json(); })
        .then(function(d) { if (d.data) document.getElementById('reunionesTotal').textContent = d.data.length; })
        .catch(function() {});
    }
    loadAnalytics();
  </script>
</body>
</html>
