---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);

const cards = [
  { icon: 'bi-robot', title: i.appsClaude, desc: i.appsClaudeDesc },
  { icon: 'bi-table', title: i.appsAirtable, desc: i.appsAirtableDesc },
  { icon: 'bi-lightning-charge', title: i.appsAWS, desc: i.appsAWSDesc },
  { icon: 'bi-github', title: i.appsGitHub, desc: i.appsGitHubDesc },
  { icon: 'bi-building', title: i.appsEnterprise, desc: i.appsEnterpriseDesc },
  { icon: 'bi-person-workspace', title: i.appsPymes, desc: i.appsPymesDesc },
];
---

<section id="apps-ia" class="relative py-24 overflow-hidden bg-dark-bg-2/50">
  <canvas id="aiParticles" class="absolute inset-0 z-0 pointer-events-none"></canvas>
  <div class="blob -right-[100px] top-[10%]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-accent-gold text-sm font-semibold tracking-widest uppercase">{i.appsLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.appsTitle}</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">{i.appsDesc}</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      {cards.map(card => (
        <div class="glass-card card-glow p-7 border-accent-gold/10 hover:-translate-y-2 transition-all duration-300 animate-on-scroll">
          <span class="w-12 h-12 rounded-xl bg-accent-gold/10 flex items-center justify-center text-xl text-accent-gold mb-4">
            <i class={`bi ${card.icon}`}></i>
          </span>
          <h3 class="text-white font-bold mb-2">{card.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-8 animate-on-scroll">
      {['Claude|bi-robot', 'Airtable|bi-table', 'AWS|bi-cloud', 'GitHub|bi-github', 'SAP|bi-hexagon', 'Groq|bi-cpu', 'Gemini|bi-gem', 'Grok|bi-lightning-charge'].map(item => {
        const [name, icon] = item.split('|');
        return (
          <div class="flex flex-col items-center gap-2 text-text-muted hover:text-primary transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-2xl border border-white/10">
              <i class={`bi ${icon}`}></i>
            </div>
            <span class="text-xs font-medium">{name}</span>
          </div>
        );
      })}
    </div>
  </div>
</section>
