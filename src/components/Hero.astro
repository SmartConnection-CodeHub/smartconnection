---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
---

<section class="relative min-h-screen flex items-center overflow-hidden" id="inicio">
  <canvas id="heroCanvas" class="absolute inset-0 z-[1]"></canvas>
  <div class="hero-glow w-[500px] h-[500px] -left-[100px] top-[20%] bg-primary/20 z-0"></div>
  <div class="hero-glow w-[400px] h-[400px] right-[-50px] bottom-[10%] bg-accent-gold/15 z-0"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-dark-bg/40 via-dark-bg/30 to-dark-bg z-[2]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-[3]">
    <div class="max-w-3xl" style="animation: fadeInUp 1s ease forwards;">
      <div class="hero-badge inline-flex items-center gap-2 bg-primary/10 border border-primary/20 rounded-full px-5 py-2 text-xs font-medium text-primary mb-8 backdrop-blur-sm">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        {i.heroBadge}
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        <span class="highlight">{i.heroTitle1}</span> + <span class="highlight-gold">{i.heroTitle2}</span> {i.heroTitle3}
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-10 max-w-2xl">
        {i.heroDesc}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#servicios-sap" class="bg-primary hover:bg-primary-light text-dark-bg font-bold px-7 py-3.5 rounded-xl text-sm transition-all flex items-center gap-2 shadow-lg shadow-primary/20">
          <i class="bi bi-gear-wide-connected"></i> {i.heroBtnSAP}
        </a>
        <a href="#apps-ia" class="bg-accent-gold hover:brightness-110 text-dark-bg font-bold px-7 py-3.5 rounded-xl text-sm transition-all flex items-center gap-2">
          <i class="bi bi-robot"></i> {i.heroBtnApps}
        </a>
        <a href="#" class="border border-white/20 hover:border-white/40 text-white font-semibold px-7 py-3.5 rounded-xl text-sm transition-all flex items-center gap-2 backdrop-blur-sm" onclick="openScheduler(); return false;">
          <i class="bi bi-calendar-check"></i> {i.heroBtnSchedule}
        </a>
      </div>
    </div>
  </div>
</section>
