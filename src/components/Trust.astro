---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
---

<section id="clientes" class="relative py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12 animate-on-scroll">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase">{i.trustLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.trustTitle}</h2>
      <p class="text-text-muted max-w-2xl mx-auto">{i.trustDesc}</p>
    </div>
    <div class="marquee-wrapper animate-on-scroll">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          <>
            {[
              { name: 'SAP', icon: 'bi-hexagon-fill', href: 'https://www.sap.com' },
              { name: 'AWS', icon: 'bi-cloud-fill', href: 'https://aws.amazon.com' },
              { name: 'Claude AI', icon: 'bi-robot', href: 'https://www.anthropic.com' },
              { name: 'GitHub', icon: 'bi-github', href: 'https://github.com' },
              { name: 'Airtable', icon: 'bi-table', href: 'https://www.airtable.com' },
              { name: 'Groq', icon: 'bi-cpu', href: 'https://groq.com' },
              { name: 'Google AI', icon: 'bi-gem', href: 'https://ai.google' },
              { name: 'Grok', icon: 'bi-lightning-charge', href: 'https://x.ai' },
              { name: 'Node.js', icon: 'bi-terminal-fill', href: 'https://nodejs.org' },
              { name: 'Google WS', icon: 'bi-google', href: 'https://workspace.google.com' },
            ].map(tech => (
              <a href={tech.href} target="_blank" rel="noopener" class="marquee-item flex flex-col items-center gap-2 p-5 rounded-xl bg-white/[0.03] border border-white/5 hover:border-primary/20 hover:bg-primary/5 transition-all group flex-shrink-0 min-w-[140px]">
                <div class="text-2xl text-text-muted group-hover:text-primary transition-colors">
                  <i class={`bi ${tech.icon}`}></i>
                </div>
                <span class="text-xs text-text-muted group-hover:text-white transition-colors">{tech.name}</span>
              </a>
            ))}
          </>
        ))}
      </div>
    </div>
  </div>
</section>
