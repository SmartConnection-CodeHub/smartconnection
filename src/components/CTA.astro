---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
---

<section class="relative py-20 bg-gradient-to-r from-primary/10 via-dark-bg to-primary/10 overflow-hidden">
  <div class="cta-beam"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8 animate-on-scroll">
      <div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-white flex items-center gap-3">
          <i class="bi bi-calendar-check text-primary"></i> {i.ctaTitle}
        </h2>
        <p class="text-text-muted mt-2">{i.ctaDesc}</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <button class="bg-primary hover:bg-primary-light text-dark-bg font-bold px-8 py-4 rounded-xl transition-all flex items-center gap-2" onclick="openScheduler()">
          <i class="bi bi-calendar-plus"></i> {i.ctaBtnSchedule}
        </button>
        <a href="#contacto" class="border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-4 rounded-xl transition-all flex items-center gap-2">
          <i class="bi bi-chat-dots"></i> {i.ctaBtnMessage}
        </a>
      </div>
    </div>
  </div>
</section>
