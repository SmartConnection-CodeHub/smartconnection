---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);
---

<section id="contacto" class="relative py-24 overflow-hidden">
  <div class="blob -left-[150px] -top-[100px]"></div>
  <div class="blob -right-[100px] -bottom-[80px]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase">{i.contactLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.contactTitle}</h2>
      <p class="text-text-muted">{i.contactDesc}</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div class="animate-on-scroll">
        <h3 class="text-white text-2xl font-bold mb-8">Smart Connection</h3>
        {[
          { icon: 'bi-geo-alt', title: i.contactOffice, content: 'Barros Borgoño 71, Providencia, Santiago' },
          { icon: 'bi-telephone', title: i.contactPhone, content: '<a href="tel:+56955361419" class="text-text-muted hover:text-primary transition-colors block py-1">+56 9 5536 1419</a><a href="tel:+56977008176" class="text-text-muted hover:text-primary transition-colors block py-1">+56 9 7700 8176</a>' },
          { icon: 'bi-envelope', title: i.contactEmail, content: '<a href="mailto:contacto@smconnection.cl" class="text-text-muted hover:text-primary transition-colors">contacto@smconnection.cl</a>' },
          { icon: 'bi-linkedin', title: i.contactLinkedIn, content: `<a href="https://www.linkedin.com/company/smconnection/" target="_blank" rel="noopener" class="text-text-muted hover:text-primary transition-colors">${i.contactFollowLinkedIn}</a>` },
        ].map(item => (
          <div class="flex gap-4 mb-6">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-xl text-primary shrink-0">
              <i class={`bi ${item.icon}`}></i>
            </div>
            <div>
              <h4 class="text-white font-semibold mb-1">{item.title}</h4>
              <div class="text-text-muted text-sm" set:html={item.content}></div>
            </div>
          </div>
        ))}
      </div>
      <div class="glass-card p-8 animate-on-scroll">
        <form id="contactForm" novalidate>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="nombre" class="block text-sm text-text-muted mb-2">{i.contactFormName}</label>
              <input type="text" id="nombre" name="nombre" required placeholder={i.contactFormNamePh} class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors">
            </div>
            <div>
              <label for="empresa" class="block text-sm text-text-muted mb-2">{i.contactFormCompany}</label>
              <input type="text" id="empresa" name="empresa" placeholder={i.contactFormCompanyPh} class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors">
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="email" class="block text-sm text-text-muted mb-2">{i.contactFormEmail}</label>
              <input type="email" id="email" name="email" required placeholder="tu@email.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors">
            </div>
            <div>
              <label for="telefono" class="block text-sm text-text-muted mb-2">{i.contactFormPhone}</label>
              <input type="tel" id="telefono" name="telefono" placeholder={i.contactFormPhonePh} class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors">
            </div>
          </div>
          <div class="mb-4">
            <label for="servicio" class="block text-sm text-text-muted mb-2">{i.contactFormService}</label>
            <select id="servicio" name="servicio" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors">
              <option value="">{i.contactFormServicePh}</option>
              <option value="SAP">{i.contactFormServiceSAP}</option>
              <option value="App con IA">{i.contactFormServiceApp}</option>
              <option value="PYME">{i.contactFormServicePyme}</option>
              <option value="Otro">{i.contactFormServiceOther}</option>
            </select>
          </div>
          <div class="mb-6">
            <label for="mensaje" class="block text-sm text-text-muted mb-2">{i.contactFormMessage}</label>
            <textarea id="mensaje" name="mensaje" required placeholder={i.contactFormMessagePh} rows="4" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm focus:border-primary focus:outline-none transition-colors resize-y"></textarea>
          </div>
          <div class="hp-field">
            <label>No llenar</label>
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </div>
          <button type="submit" class="w-full bg-primary hover:bg-primary-light text-dark-bg font-bold py-3.5 rounded-xl text-sm transition-all flex items-center justify-center gap-2">
            <i class="bi bi-send"></i> {i.contactFormSubmit}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
