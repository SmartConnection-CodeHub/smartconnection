---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);

const projects = [
  {
    title: i.portfolioVOY,
    desc: i.portfolioVOYDesc,
    tech: i.portfolioVOYTech,
    img: '/img/portfolio/voy.svg',
    color: '#059669',
    bgColor: 'rgba(5,150,105,0.1)',
  },
  {
    title: i.portfolioInfoPet,
    desc: i.portfolioInfoPetDesc,
    tech: i.portfolioInfoPetTech,
    img: '/img/portfolio/infopet.svg',
    color: '#f59e0b',
    bgColor: 'rgba(245,158,11,0.1)',
  },
  {
    title: i.portfolioSMC,
    desc: i.portfolioSMCDesc,
    tech: i.portfolioSMCTech,
    img: '/img/portfolio/smconnection.svg',
    color: '#00c1c1',
    bgColor: 'rgba(0,193,193,0.1)',
  },
  {
    title: i.portfolioIntranet,
    desc: i.portfolioIntranetDesc,
    tech: i.portfolioIntranetTech,
    img: '/img/portfolio/intranet.svg',
    color: '#8b5cf6',
    bgColor: 'rgba(139,92,246,0.1)',
  },
];
---

<section id="portafolio" class="relative py-24 overflow-hidden bg-dark-bg-2/30">
  <div class="blob -left-[200px] top-[20%]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-accent-gold text-sm font-semibold tracking-widest uppercase">{i.portfolioLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.portfolioTitle}</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">{i.portfolioDesc}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map(project => (
        <div class="glass-card overflow-hidden hover:-translate-y-2 transition-all duration-300 animate-on-scroll group">
          <div class="relative h-48 overflow-hidden bg-dark-bg-3">
            <img
              src={project.img}
              alt={project.title}
              loading="lazy"
              class="w-full h-full object-cover object-top opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            >
            <div class="absolute inset-0 items-center justify-center text-6xl hidden" style={`color:${project.color}`}>
              <i class="bi bi-image"></i>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent"></div>
            <span class="absolute top-4 right-4 text-xs font-semibold px-3 py-1 rounded-full border" style={`background:${project.bgColor};color:${project.color};border-color:${project.color}30`}>
              {i.portfolioTag}
            </span>
          </div>
          <div class="p-6">
            <h3 class="text-white font-bold text-lg mb-2">{project.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">{project.desc}</p>
            <div class="flex flex-wrap gap-2">
              {project.tech.split(' · ').map(t => (
                <span class="text-xs px-2.5 py-1 rounded-full bg-white/5 text-text-muted border border-white/10">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
