---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);

const waMsg = encodeURIComponent(i.whatsappMessage);
---

<footer class="bg-dark-bg-2 border-t border-white/5 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <div>
        <img src="/img/logo_smart_white.svg" alt="Smart Connection" width="160" height="30" loading="lazy" class="mb-4">
        <p class="text-text-muted text-sm leading-relaxed mb-4">{i.footerDesc}</p>
        <div class="flex gap-3">
          <a href="https://www.linkedin.com/company/smconnection/" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 inline-flex items-center justify-center text-text-muted hover:text-primary hover:bg-primary/10 transition-all">
            <i class="bi bi-linkedin"></i>
          </a>
          <a href="https://www.instagram.com/smconnection.cl/" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 inline-flex items-center justify-center text-text-muted hover:text-[#E1306C] hover:bg-[#E1306C]/10 transition-all">
            <i class="bi bi-instagram"></i>
          </a>
          <a href="https://x.com/smconnection" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 inline-flex items-center justify-center text-text-muted hover:text-white hover:bg-white/10 transition-all">
            <i class="bi bi-twitter-x"></i>
          </a>
          <a href="https://www.youtube.com/@smconnection" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 inline-flex items-center justify-center text-text-muted hover:text-[#FF0000] hover:bg-[#FF0000]/10 transition-all">
            <i class="bi bi-youtube"></i>
          </a>
        </div>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">{i.footerSAPServices}</h4>
        <ul class="space-y-2">
          {['SAP BTP', 'Migraciones S/4HANA', 'ABAP & FIORI', 'PI/PO & CPI', 'AMS & Soporte'].map(s => (
            <li><a href="#servicios-sap" class="text-text-muted text-sm hover:text-primary transition-colors">{s}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">{i.footerAppsIA}</h4>
        <ul class="space-y-2">
          {['Claude Code', 'Airtable', 'AWS Deploy', 'GitHub CI/CD'].map(s => (
            <li><a href="#apps-ia" class="text-text-muted text-sm hover:text-primary transition-colors">{s}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold mb-4">{i.footerContact}</h4>
        <ul class="space-y-2">
          <li><a href="tel:+56955361419" class="text-text-muted text-sm hover:text-primary transition-colors">+56 9 5536 1419</a></li>
          <li><a href="tel:+56977008176" class="text-text-muted text-sm hover:text-primary transition-colors">+56 9 7700 8176</a></li>
          <li><a href="mailto:contacto@smconnection.cl" class="text-text-muted text-sm hover:text-primary transition-colors">contacto@smconnection.cl</a></li>
          <li><span class="text-text-muted text-sm">Barros Borgoño 71, Providencia</span></li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-center pt-8 border-t border-white/5 text-text-muted text-xs">
      <span>{i.footerCopyright}</span>
      <span>{i.footerLocation}</span>
    </div>
  </div>
</footer>

<!-- WhatsApp Float -->
<a href={`https://wa.me/56955361419?text=${waMsg}`} class="fixed bottom-6 right-6 w-14 h-14 bg-[#25d366] rounded-full flex items-center justify-center text-white text-2xl shadow-lg z-[999] hover:scale-110 transition-transform" target="_blank" rel="noopener" aria-label="WhatsApp" style="animation: whatsappPulse 2s infinite;">
  <i class="bi bi-whatsapp"></i>
</a>
