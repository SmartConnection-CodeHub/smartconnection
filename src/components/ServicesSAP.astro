---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t(lang);

const services = [
  { icon: 'bi-cloud-arrow-up', title: i.sapBTP, desc: i.sapBTPDesc, badge: i.sapBadgeCloud },
  { icon: 'bi-arrow-repeat', title: i.sapMigrations, desc: i.sapMigrationsDesc, badge: i.sapBadgeS4 },
  { icon: 'bi-code-slash', title: i.sapABAP, desc: i.sapABAPDesc, badge: i.sapBadgeDev },
  { icon: 'bi-diagram-3', title: i.sapIntegration, desc: i.sapIntegrationDesc, badge: i.sapBadgeInt },
  { icon: 'bi-bar-chart-line', title: i.sapAnalytics, desc: i.sapAnalyticsDesc, badge: i.sapBadgeAnalytics },
  { icon: 'bi-phone', title: i.sapMobile, desc: i.sapMobileDesc, badge: i.sapBadgeMobile },
  { icon: 'bi-building-gear', title: i.sapPortal, desc: i.sapPortalDesc, badge: i.sapBadgeEnterprise },
  { icon: 'bi-headset', title: i.sapAMS, desc: i.sapAMSDesc, badge: i.sapBadgeSupport },
];
---

<section id="servicios-sap" class="relative py-24 overflow-hidden">
  <div class="blob -left-[200px] top-[10%]"></div>
  <div class="blob -right-[150px] bottom-[5%]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase">{i.sapLabel}</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">{i.sapTitle}</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">{i.sapDesc}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {services.map(svc => (
        <div class="glass-card card-glow p-7 hover:-translate-y-2 transition-all duration-300 group animate-on-scroll">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl text-primary mb-5 group-hover:bg-primary/20 transition-colors">
            <i class={`bi ${svc.icon}`}></i>
          </div>
          <h3 class="text-white font-bold text-lg mb-3">{svc.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed mb-4">{svc.desc}</p>
          <span class="inline-block bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full border border-primary/20">{svc.badge}</span>
        </div>
      ))}
    </div>
  </div>
</section>
