---
export const prerender = false;
import { verifySession } from '../api/auth';

const session = verifySession(Astro.cookies.get('sc_session')?.value);
if (!session.valid) return Astro.redirect('/intranet');
---
<!DOCTYPE html>
<html lang="es-CL">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Leads — Intranet Smart Connection</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="shortcut icon" href="/img/smart.ico">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --primary: #00c1c1; --primary-light: #00e5e5; --gold: #f0ab00; --bg: #0a0e17; --bg2: #111827; --text: #e2e8f0; --muted: #94a3b8; }
    body { font-family: 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    .topbar { background: var(--bg2); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; }
    .topbar img { height: 32px; }
    .topbar .badge { background: var(--primary); color: var(--bg); font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; }
    .topbar nav { margin-left: auto; display: flex; gap: 1rem; }
    .topbar nav a { color: var(--muted); font-size: 0.8rem; text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 8px; transition: all 0.2s; }
    .topbar nav a:hover, .topbar nav a.active { color: var(--primary); background: rgba(0,193,193,0.1); }
    .main { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }
    h1 i { color: var(--primary); }
    .filters { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .filters select, .filters input { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 0.5rem 1rem; color: #fff; font-size: 0.8rem; outline: none; }
    .filters select:focus, .filters input:focus { border-color: var(--primary); }
    table { width: 100%; border-collapse: collapse; background: var(--bg2); border-radius: 12px; overflow: hidden; }
    th { text-align: left; padding: 0.75rem 1rem; font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid rgba(255,255,255,0.05); }
    td { padding: 0.75rem 1rem; font-size: 0.8rem; border-bottom: 1px solid rgba(255,255,255,0.03); }
    tr:hover td { background: rgba(0,193,193,0.03); }
    .badge-status { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 999px; font-weight: 600; }
    .badge-nuevo { background: rgba(0,193,193,0.15); color: var(--primary); }
    .badge-contactado { background: rgba(240,171,0,0.15); color: var(--gold); }
    .badge-cerrado { background: rgba(34,197,94,0.15); color: #22c55e; }
    .empty { text-align: center; padding: 3rem; color: var(--muted); }
  </style>
</head>
<body>
  <div class="topbar">
    <img src="/img/logo_smart.svg" alt="Smart Connection">
    <span class="badge">INTRANET</span>
    <nav>
      <a href="/intranet">Dashboard</a>
      <a href="/intranet/leads" class="active">Leads</a>
      <a href="/intranet/analytics">Analytics</a>
    </nav>
  </div>
  <div class="main">
    <h1><i class="bi bi-people"></i> Leads CRM</h1>
    <div class="filters">
      <select id="filterEstado">
        <option value="">Todos los estados</option>
        <option value="nuevo">Nuevo</option>
        <option value="contactado">Contactado</option>
        <option value="cerrado">Cerrado</option>
      </select>
      <select id="filterServicio">
        <option value="">Todos los servicios</option>
        <option value="SAP">SAP</option>
        <option value="App con IA">App con IA</option>
        <option value="PYME">PYME</option>
      </select>
      <input type="text" id="filterSearch" placeholder="Buscar por nombre o email...">
    </div>
    <table>
      <thead>
        <tr><th>Fecha</th><th>Nombre</th><th>Email</th><th>Empresa</th><th>Servicio</th><th>Estado</th><th>Mensaje</th></tr>
      </thead>
      <tbody id="leadsBody">
        <tr><td colspan="7" class="empty">Cargando...</td></tr>
      </tbody>
    </table>
  </div>
  <script is:inline>
    var allLeads = [];
    function loadLeads() {
      fetch('/api/contact', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{"action":"list_leads"}' })
        .then(function(r) { return r.json(); })
        .then(function(d) { /* fallback: load from agents API */ })
        .catch(function() {});
      // Direct Supabase query via a simple proxy
      fetch('/api/agents', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({action:'query', table:'leads', order:'created_at.desc', limit:100}) })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.data) { allLeads = d.data; renderLeads(); }
        })
        .catch(function() {
          document.getElementById('leadsBody').innerHTML = '<tr><td colspan="7" class="empty">Sin leads todavia</td></tr>';
        });
    }
    function renderLeads() {
      var tbody = document.getElementById('leadsBody');
      var estado = document.getElementById('filterEstado').value;
      var servicio = document.getElementById('filterServicio').value;
      var search = document.getElementById('filterSearch').value.toLowerCase();
      var filtered = allLeads.filter(function(l) {
        if (estado && l.estado !== estado) return false;
        if (servicio && l.servicio !== servicio) return false;
        if (search && !(l.nombre||'').toLowerCase().includes(search) && !(l.email||'').toLowerCase().includes(search)) return false;
        return true;
      });
      if (filtered.length === 0) { tbody.innerHTML = '<tr><td colspan="7" class="empty">Sin resultados</td></tr>'; return; }
      tbody.innerHTML = filtered.map(function(l) {
        var date = new Date(l.created_at).toLocaleDateString('es-CL');
        var badgeClass = l.estado === 'nuevo' ? 'badge-nuevo' : l.estado === 'contactado' ? 'badge-contactado' : 'badge-cerrado';
        return '<tr><td>' + date + '</td><td>' + (l.nombre||'') + '</td><td>' + (l.email||'') + '</td><td>' + (l.empresa||'-') + '</td><td>' + (l.servicio||'-') + '</td><td><span class="badge-status ' + badgeClass + '">' + (l.estado||'nuevo') + '</span></td><td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (l.mensaje||'') + '</td></tr>';
      }).join('');
    }
    document.getElementById('filterEstado').addEventListener('change', renderLeads);
    document.getElementById('filterServicio').addEventListener('change', renderLeads);
    document.getElementById('filterSearch').addEventListener('input', renderLeads);
    loadLeads();
  </script>
</body>
</html>
